# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Gmail
GMAIL_USER_EMAIL=             # The Gmail address to monitor

# Gmail Pub/Sub (required for setup scripts + renew-watch endpoint)
GCP_PROJECT_ID=
GMAIL_PUBSUB_TOPIC=           # projects/{project-id}/topics/{topic-name}

# Bandcamp
# Get from: DevTools → Application → Cookies → bandcamp.com → 'identity'
BANDCAMP_IDENTITY_COOKIE=

# Webhook security — random string appended as ?token= to the Pub/Sub push URL
WEBHOOK_SECRET=
