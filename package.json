{
    "name": "bandcamp-code-redeem",
    "version": "1.0.0",
    "description": "Monitors Gmail for Bandcamp download code emails and redeems them automatically.",
    "type": "module",
    "scripts": {
        "dev": "vercel dev",
        "build": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/ api/ scripts/",
        "lint:fix": "eslint src/ api/ scripts/ --fix",
        "setup:oauth": "tsx --env-file=.env.local scripts/setup-oauth.ts",
        "setup:watch": "tsx --env-file=.env.local scripts/setup-watch.ts",
        "test:redeem": "tsx --env-file=.env.local scripts/test-redeem.ts"
    },
    "dependencies": {
        "cheerio": "^1.2.0",
        "googleapis": "^144.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@barnemax/bandcamp-types": "^0.1.5",
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.19.17",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vercel/node": "^5.7.5",
        "eslint": "^10.2.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.2",
        "vercel": "^41.7.8",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "packageManager": "pnpm@9.15.4",
    "pnpm": {
        "ignoredBuiltDependencies": [
            "esbuild"
        ]
    }
}